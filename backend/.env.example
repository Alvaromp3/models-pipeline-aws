# Copiar a .env y rellenar. No commitear .env con secretos reales.
DATABASE_URL=postgresql://novaretail:novaretail_dev@localhost:5432/novaretail
PORT=4000

JWT_SECRET=dev-only-change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=8h

ML_SERVICE_URL=http://localhost:8000
# Separar por coma si usas varios orígenes (p. ej. localhost y 127.0.0.1).
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Cognito Hosted UI (valores de ejemplo; sustituir por tu pool)
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1
# Pool id debe coincidir con el claim iss del id_token (mayúsculas/minúsculas). Si define COGNITO_ISSUER URL completa, tiene prioridad sobre COGNITO_USER_POOL_ID.
COGNITO_USER_POOL_ID=
COGNITO_DOMAIN=
COGNITO_ISSUER=
COGNITO_REDIRECT_URI=http://localhost:8080/auth/callback
# Secreto del App client (solo si en Cognito el cliente NO es "público"):
# - Cliente público (típico SPA): no defina COGNITO_CLIENT_SECRET (o vacío). Si pone un valor incorrecto → invalid_client_secret.
# - Cliente con secreto: pegue el secreto exacto de la consola (sin comillas). Si lo rotó, actualice .env y reinicie el API.
# COGNITO_CLIENT_SECRET=

AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
