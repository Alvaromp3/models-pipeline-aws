# En portátil sin EC2, evita que el SDK intente metadatos (169.254.169.254) y colgue el arranque.
AWS_EC2_METADATA_DISABLED=true

# Credenciales / región (misma cuenta que el bucket; o perfil IAM en EC2/ECS).
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Objetos en S3 (rutas dentro del bucket).
S3_MODEL_BUCKET=tu-bucket
S3_REVENUE_MODEL_KEY=models/revenue_model.joblib
S3_STOCKOUT_MODEL_KEY=models/stockout_risk_model.joblib

# Solo S3: no cargar .joblib desde disco aunque existan en models_local.
ML_SKIP_LOCAL=1
ML_MODEL_ORDER=s3_first

# Opcional si en algún momento quieres probar local sin S3:
# ML_SKIP_LOCAL=0
# ML_MODEL_ORDER=local_first
# LOCAL_MODEL_DIR=./models_local
